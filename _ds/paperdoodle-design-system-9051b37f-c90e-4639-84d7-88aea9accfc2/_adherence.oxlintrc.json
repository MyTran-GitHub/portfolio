{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/feedback/**",
              "components/forms/**",
              "components/layout/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Caveat|Patrick Hand|Kalam|Gloria Hallelujah))/i]",
        "message": "Font not provided by the design system. Available: Caveat, Patrick Hand, Kalam, Gloria Hallelujah."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|blue|lavender|red|mint|yellow|solid)$/]",
        "message": "<Badge> tone must be one of 'default' | 'blue' | 'lavender' | 'red' | 'mint' | 'yellow' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|tilt|stack|flat|interactive|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, tilt, stack, flat, interactive, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|radio|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, radio, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|doodle|variant|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: label, doodle, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:dashed|plain|wavy)$/]",
        "message": "<Divider> variant must be one of 'dashed' | 'plain' | 'wavy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Highlight'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|animate|children|key|ref|className|style|children)$/]",
        "message": "<Highlight> doesn't accept that prop. Declared props: color, animate, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Highlight'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:yellow|pink|mint|blue)$/]",
        "message": "<Highlight> color must be one of 'yellow' | 'pink' | 'mint' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|multiline|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, multiline."
      },
      {
        "selector": "JSXOpeningElement[name.name='WashiTape'] > JSXAttribute > JSXIdentifier[name!=/^(?:color|tilt|children|key|ref|className|style|children)$/]",
        "message": "<WashiTape> doesn't accept that prop. Declared props: color, tilt, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='WashiTape'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:yellow|pink|mint|blue|paper)$/]",
        "message": "<WashiTape> color must be one of 'yellow' | 'pink' | 'mint' | 'blue' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WrittenHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|as|level|underline|animate|key|ref|className|style|children)$/]",
        "message": "<WrittenHeading> doesn't accept that prop. Declared props: children, as, level, underline, animate."
      },
      {
        "selector": "JSXOpeningElement[name.name='WrittenHeading'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:h1|h2|h3|span)$/]",
        "message": "<WrittenHeading> as must be one of 'h1' | 'h2' | 'h3' | 'span'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WrittenHeading'] > JSXAttribute[name.name='level'] > Literal[value!=/^(?:display|h1|h2)$/]",
        "message": "<WrittenHeading> level must be one of 'display' | 'h1' | 'h2'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
